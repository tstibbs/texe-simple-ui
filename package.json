{
	"name": "@tstibbs/texecom-simple-ui",
	"private": true,
	"devEngines": {
		"runtime": {
			"name": "node",
			"version": "24",
			"onFail": "error"
		},
		"packageManager": {
			"name": "pnpm",
			"version": ">=11.7",
			"onFail": "error"
		}
	},
	"type": "module",
	"devDependencies": {
		"@tstibbs/cloud-core-base-image": "github:tstibbs/cloud-core#path:/edge/docker-base-image",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.8",
		"prettier": "^3.9.4"
	},
	"scripts": {
		"prepare": "husky install",
		"docker:build": "cloud-core-base-image build",
		"docker:deploy": "cloud-core-base-image deploy --server $device"
	}
}
